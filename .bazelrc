build --jobs=200
build --disk_cache=~/.cache/bazelcache
# Default GC limits — sized conservatively for macOS agents (disk-constrained).
build --experimental_disk_cache_gc_max_size=30G
build --experimental_disk_cache_gc_max_age=7d

# Linux CI disk-cache GC config — less aggressive because Linux agents have
# ~3 TB of disk.  2 TB cap leaves ~1 TB for the OS, working files, and other
# toolchain artefacts; 30-day max-age keeps more cached Rust/Bazel outputs
# between builds, reducing recompilation on cold caches.
# Enable with --config=ci-linux-disk-cache on Linux Buildkite steps only.
build:ci-linux-disk-cache --experimental_disk_cache_gc_max_size=2000G
build:ci-linux-disk-cache --experimental_disk_cache_gc_max_age=30d

# Always stamp builds with the git-derived version so that dev builds show a
# meaningful version string (e.g. "1.0.9-dev-a58a932") in the About panel
# instead of the unstamped placeholder "0.0.0".  Only the version plist and
# build_info_rs actions use ctx.info_file, so the cache impact is minimal —
# Swift/Rust compilation targets are unaffected.
build --workspace_status_command=tools/boss/installer/workspace-status.sh
build --stamp

# Release config: identical stamp flags; kept as a named config so release.sh
# and CI can use --config=release to opt into additional release-only settings.
build:release --workspace_status_command=tools/boss/installer/workspace-status.sh
build:release --stamp

# boss shake credentials: propagate the three env vars that embed the
# GitHub App into the binary at compile time. Values must be set in your
# shell (or via direnv) before running bazel build //tools/boss/cli:boss.
# See tools/boss/cli/README.md for the one-time developer setup instructions.
#
# --action_env is kept for belt-and-suspenders (non-rust actions, tooling).
# --define supplies the values to the rustc_env Make-variable expansion on
# the rust_binary target; rules_rust does not forward --action_env into the
# rustc compile action's env or cache key, but --define IS part of the key.
# Empty defaults here mean dev builds compile cleanly; the release pipeline
# overrides via --define=BOSS_SHAKE_APP_ID="$BOSS_SHAKE_APP_ID" etc.
build --action_env=BOSS_SHAKE_APP_ID
build --action_env=BOSS_SHAKE_INSTALLATION_ID
build --action_env=BOSS_SHAKE_PRIVATE_KEY_PEM
build --define=BOSS_SHAKE_APP_ID=
build --define=BOSS_SHAKE_INSTALLATION_ID=
build --define=BOSS_SHAKE_PRIVATE_KEY_PEM=

