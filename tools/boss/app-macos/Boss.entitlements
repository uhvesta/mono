<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Entitlements applied to bazel-built (ad-hoc signed) dev builds.
         Release builds are re-signed by installer/release.sh with
         installer/entitlements/app.entitlements, which carries the same
         keychain-access-groups entry plus hardened-runtime keys.

         keychain-access-groups gives the app a stable data-protection
         keychain access group so APIKeyStore (which passes
         kSecUseDataProtectionKeychain) can store and read the Anthropic
         API key without the legacy interactive ACL password dialog.
         The group is intentionally bare (no $(TeamIdentifierPrefix)) so
         it resolves identically for ad-hoc dev signatures, which carry
         no team identifier to substitute. Declaring exactly one group
         makes it the default access group, so APIKeyStore needs no
         explicit kSecAttrAccessGroup. -->
    <key>keychain-access-groups</key>
    <array>
        <string>dev.spinyfin.bossmacapp</string>
    </array>
</dict>
</plist>
