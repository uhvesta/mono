load("@build_bazel_rules_apple//apple:macos.bzl", "macos_unit_test")
load("@build_bazel_rules_swift//swift:swift.bzl", "swift_library")

package(default_visibility = ["//visibility:private"])

macos_unit_test(
    name = "UpdateTests",
    minimum_os_version = "15.0",
    deps = [":update_tests_lib"],
)

swift_library(
    name = "update_tests_lib",
    module_name = "UpdateTests",
    srcs = glob(["*.swift"]),
    copts = [],
    deps = ["//tools/boss/app-macos/Sources/UpdateCore:UpdateCore"],
    testonly = True,
)
