<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required: GhosttyKit loads dylibs signed with the developer cert,
         not Apple's. Without this, the hardened runtime refuses them. -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>
    <!-- Tentative: Metal shader compilation in GhosttyKit may require JIT.
         Enable only if notarytool rejects the bundle without it (Q-Risk-1).
         See design doc §Q2 for the validation plan. -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <!-- Stable data-protection keychain access group so APIKeyStore reads
         the Anthropic API key without the legacy interactive password
         dialog. Must match tools/boss/app-macos/Boss.entitlements (the
         dev-build entitlements) so a stored key stays readable across
         ad-hoc and Developer ID signatures. Bare (no $(TeamIdentifierPrefix))
         to match the dev build, which has no team identifier to substitute. -->
    <key>keychain-access-groups</key>
    <array>
        <string>dev.spinyfin.bossmacapp</string>
    </array>
</dict>
</plist>
