rust_binary(
    name = "engine",
    srcs = ["src/main.rs"],
    edition = "2024",
    # Ship the boss-event hook shim alongside the engine binary so
    # PaneSpawnRunner can resolve it via runfiles at runtime. Without
    # this dep, `bazel run //tools/boss/engine:engine` builds only
    # the engine and worker `settings.json` ends up referencing
    # `boss-event` as a bare name that isn't on the worker's
    # sanitized PATH — every hook fires `command not found`.
    data = ["//tools/boss/event-shim:boss-event"],
    visibility = [
        "//tools/boss/app-macos:__pkg__",
        "//tools/boss/installer:__pkg__",
    ],
    deps = [
        ":engine_lib",
    ] + all_crate_deps(normal = True),
    proc_macro_deps = all_crate_deps(proc_macro = True),
)

# engine_lib_test is split into 4 parallel shards to cut wall time.
# Rust's libtest does not honour TEST_SHARD_INDEX / TEST_TOTAL_SHARDS, so
# shard_count would silently re-run the full suite N times.  Instead we
# create 4 rust_test targets with disjoint test-name filters (positional
# FILTERS and --skip flags) so Bazel schedules them in parallel.
# Coverage is identical: the 4 filter sets partition all 1145 tests with
# no overlap.  A test_suite keeps `bazel test :engine_lib_test` working.
#
# All shards share size = "small" / timeout = "moderate" (300 s):
#   linux-amd64 CI runners run ~6-7x slower than macOS dev boxes, so the
#   60 s default for size="small" is too tight even per-shard.
# All shards set env = {"HOME": "/tmp"}:
#   Bazel's sandbox does not inherit HOME; tests that call
#   cube_default_workspace_root_for_test need a stable sentinel value.

# Shard 1 — work module (~226 tests, the single heaviest slice ~7s on macOS)
rust_test(
    name = "engine_lib_test_work",
    crate = ":engine_lib",
    edition = "2024",
    size = "small",
    timeout = "moderate",
    args = ["work::"],
    env = {"HOME": "/tmp"},
    deps = all_crate_deps(normal = True, normal_dev = True),
    proc_macro_deps = all_crate_deps(proc_macro = True, proc_macro_dev = True),
)

# Shard 2 — app + dispatch + conflict + ci_log_reader (~164 tests, ~5s on macOS)
rust_test(
    name = "engine_lib_test_a",
    crate = ":engine_lib",
    edition = "2024",
    size = "small",
    timeout = "moderate",
    args = [
        "app::",
        "dispatch_events::",
        "dispatch_reader::",
        "conflict_diagnosis::",
        "conflict_watch::",
        "ci_log_reader::",
    ],
    env = {"HOME": "/tmp"},
    deps = all_crate_deps(normal = True, normal_dev = True),
    proc_macro_deps = all_crate_deps(proc_macro = True, proc_macro_dev = True),
)

# Shard 3 — completion + coordinator + merge_poller + external_tracker +
#           live_status* + runner + build_info (~358 tests, ~7s on macOS)
rust_test(
    name = "engine_lib_test_b",
    crate = ":engine_lib",
    edition = "2024",
    size = "small",
    timeout = "moderate",
    args = [
        "completion::",
        "coordinator::",
        "merge_poller::",
        "external_tracker::",
        "live_status::",
        "live_status_loop::",
        "live_status_redact::",
        "runner::",
        "build_info::",
        # nudge_breaker is pure in-memory (no global state) and is the
        # auto-nudge sibling of completion; group it here rather than in
        # shard 4 so it doesn't add parallelism to that shard's
        # global-state-sharing tests (audit/worker_setup).
        "nudge_breaker::",
    ],
    env = {"HOME": "/tmp"},
    deps = all_crate_deps(normal = True, normal_dev = True),
    proc_macro_deps = all_crate_deps(proc_macro = True, proc_macro_dev = True),
)

