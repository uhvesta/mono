load("@rules_rust//rust:defs.bzl", "rust_binary", "rust_library", "rust_test")
load("@mono_crates//:defs.bzl", "all_crate_deps")

rust_library(
    name = "engine_lib",
    crate_name = "boss_engine",
    srcs = [
        "src/app.rs",
        "src/audit.rs",
        "src/audit_effort.rs",
        "src/build_info.rs",
        "src/ci_watch.rs",
        "src/cli.rs",
        "src/completion.rs",
        "src/config.rs",
        "src/conflict_diagnosis.rs",
        "src/conflict_watch.rs",
        "src/coordinator.rs",
        "src/dispatch_events.rs",
        "src/dispatch_reader.rs",
        "src/effort.rs",
        "src/events_socket.rs",
        "src/lib.rs",
        "src/live_status.rs",
        "src/live_status_loop.rs",
        "src/live_status_redact.rs",
        "src/live_worker_state.rs",
        "src/merge_poller.rs",
        "src/orphan_sweep.rs",
        "src/pane_summary.rs",
        "src/pr_url_capture.rs",
        "src/protocol.rs",
        "src/run_reconcile.rs",
        "src/runner.rs",
        "src/spawn_flow.rs",
        "src/transcript_tail.rs",
        "src/work.rs",
        "src/work_dependencies.rs",
        "src/worker_registry.rs",
        "src/worker_sandbox_audit.rs",
        "src/worker_setup.rs",
    ],
    crate_root = "src/lib.rs",
    edition = "2024",
    visibility = [
        "//tools/boss/bossctl:__pkg__",
        "//tools/boss/cli:__pkg__",
        "//tools/boss/client:__pkg__",
        "//tools/boss/engine:__pkg__",
    ],
    deps = [
        "//tools/boss/protocol",
    ] + all_crate_deps(normal = True),
    proc_macro_deps = all_crate_deps(proc_macro = True),
)

rust_binary(
    name = "engine",
    srcs = ["src/main.rs"],
    edition = "2024",
    # Ship the boss-event hook shim alongside the engine binary so
    # PaneSpawnRunner can resolve it via runfiles at runtime. Without
    # this dep, `bazel run //tools/boss/engine:engine` builds only
    # the engine and worker `settings.json` ends up referencing
    # `boss-event` as a bare name that isn't on the worker's
    # sanitized PATH — every hook fires `command not found`.
    data = ["//tools/boss/event-shim:boss-event"],
    deps = [
        ":engine_lib",
    ] + all_crate_deps(normal = True),
    proc_macro_deps = all_crate_deps(proc_macro = True),
)

rust_test(
    name = "engine_lib_test",
    crate = ":engine_lib",
    edition = "2024",
    size = "small",
    deps = all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
)

rust_test(
    name = "work_crud_test",
    srcs = ["tests/work_crud.rs"],
    edition = "2024",
    deps = [
        ":engine_lib",
        "//tools/boss/client",
        "//tools/boss/protocol",
    ] + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
)

rust_test(
    name = "control_verbs_test",
    srcs = ["tests/control_verbs.rs"],
    edition = "2024",
    deps = [
        ":engine_lib",
        "//tools/boss/client",
        "//tools/boss/protocol",
    ] + all_crate_deps(
        normal = True,
        normal_dev = True,
    ),
    proc_macro_deps = all_crate_deps(
        proc_macro = True,
        proc_macro_dev = True,
    ),
)
