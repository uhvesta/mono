    edition = "2024",
    size = "small",
    timeout = "moderate",
    args = [
        "--skip", "work::",
        "--skip", "app::",
        "--skip", "dispatch_events::",
        "--skip", "dispatch_reader::",
        "--skip", "conflict_diagnosis::",
        "--skip", "conflict_watch::",
        "--skip", "ci_log_reader::",
        "--skip", "completion::",
        "--skip", "coordinator::",
        "--skip", "merge_poller::",
        "--skip", "external_tracker::",
        "--skip", "live_status::",
        "--skip", "live_status_loop::",
        "--skip", "live_status_redact::",
        "--skip", "runner::",
        "--skip", "build_info::",
        "--skip", "nudge_breaker::",
    ],
    env = {"HOME": "/tmp"},
    deps = all_crate_deps(normal = True, normal_dev = True),
    proc_macro_deps = all_crate_deps(proc_macro = True, proc_macro_dev = True),
)

# Umbrella target: `bazel test //tools/boss/engine:engine_lib_test` runs all
# 4 shards in parallel (subject to --jobs).
test_suite(
    name = "engine_lib_test",
    tests = [
        ":engine_lib_test_work",
        ":engine_lib_test_a",
        ":engine_lib_test_b",
        ":engine_lib_test_rest",
    ],
)

