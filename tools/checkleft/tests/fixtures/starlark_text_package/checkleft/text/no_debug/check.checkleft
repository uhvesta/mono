load("//lib/messages", "policy_message")

check_meta(applies_to = ["**/*.txt"])

def check(ctx):
    findings = []
    for file in ctx.files:
        for line in file.added_lines:
            if "debug" in line.text:
                findings.append(fail(
                    message = policy_message("debug"),
                    path = file.path,
                    line = line.number,
                    column = 1,
                ))
    return findings
