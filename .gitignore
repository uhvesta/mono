# Bazel
/bazel-*

# repobin-managed tool binaries and symlinks (generated by `repobin install`).
# Committed to the workspace only as a transient CI artefact; never check in.
/bin/

# Rust
target/
/dist/

# Node
node_modules/

# Swift
.build/

# OS
.DS_Store

# Per-lease worker session artifacts written by tools/boss/engine/src/worker_setup.rs.
# These contain a specific lease id and worker config, regenerated each spawn.
.claude/

# Boss engine runtime event buffer (written by event-shim to workspace root).
.boss/
.bk.yaml
